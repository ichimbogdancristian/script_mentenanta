# .gitignore - Windows Maintenance Automation Script
# Purpose: Exclude runtime artifacts, temp files, and logs from version control
# This file ensures that generated files are not committed to the repository

# ============================================================================
# Extracted Repository Folder
# ============================================================================
# When script.bat downloads and extracts the main branch as ZIP,
# it creates this folder. It should NOT be committed to version control.
script_mentenanta-main/

# ============================================================================
# Downloaded Archives
# ============================================================================
# ZIP files downloaded by script.bat for repository updates.
# These are temporary and can be regenerated by running the script.
*.zip

# ============================================================================
# Temporary Files
# ============================================================================
# temp_files/ folder created by PowerShell script for:
# - Downloaded applications
# - Temporary processing
# - Extraction of installers
# Should be cleaned up after script completion but gitignored while present
temp_files/

# ============================================================================
# Log Files
# ============================================================================
# maintenance.log is created by script.bat and script.ps1
# Contains execution history, errors, and diagnostic information
# Should not be committed as logs are specific to each execution
maintenance.log
maintenance.log.*
*.log

# ============================================================================
# Environment-Specific Files
# ============================================================================
# Configuration files that might contain sensitive information
# or be environment-specific
config/logging.json
config/settings.local.json
config/*.local.*

# ============================================================================
# Analysis and Documentation (Temporary)
# ============================================================================
# These files are generated for analysis and may not be needed
COMPREHENSIVE_ANALYSIS.md
DUPLICATE_CLEANUP_GUIDE.md
PATH_ANALYSIS.md
PATH_SYSTEM_VERIFIED.md
PATH_QUICK_REFERENCE.md

# ============================================================================
# PowerShell Debugging Files
# ============================================================================
# Transcript files created by PowerShell debugging
*.txt
*.transcript

# ============================================================================
# System Files (Windows)
# ============================================================================
# Windows system files that might be created during testing
Thumbs.db
.DS_Store  # macOS
desktop.ini

# ============================================================================
# IDE and Editor Files
# ============================================================================
# Temporary files created by IDEs and editors
.vscode/
*.swp
*.swo
*~
.idea/
*.iml

# ============================================================================
# Version Control Directories (if using Git submodules)
# ============================================================================
.git/
.gitmodules

# ============================================================================
# Runtime Artifacts - Important for Distribution
# ============================================================================
# These items should NOT be in gitignore if distributing the script
# Include them when packaging for distribution:
#   - script.bat (DO COMMIT)
#   - script.ps1 (DO COMMIT)
#   - README.md (DO COMMIT)
#   - .github/ (DO COMMIT - contains documentation)
#
# These items ARE runtime-generated and SHOULD be ignored:
#   - script_mentenanta-main/ (extracted repo)
#   - *.zip (downloaded archives)
#   - temp_files/ (temporary processing)
#   - maintenance.log (execution logs)

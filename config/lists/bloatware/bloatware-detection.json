    "oem_specific": {
      "description": "OEM pre-installed software. Includes both winget-style ids (Dell.*, HP.*) AND the real AppX publisher prefixes (DellInc.*, AD2F1837.* for HP, E046963F.* for Lenovo) so both detection sources actually match. Entries tagged \"tier\": \"broad\" are whole-vendor wildcards that can also match software the user deliberately installed (e.g. *Razer* matches Razer Synapse, which owners of Razer peripherals need to configure them) - these are only matched when modules.softwareManagement.aggressiveOemRemoval is true in main-config.json; see SoftwareManagementAudit.psm1.",
      "apps": [
        { "name": "Dell (winget)", "appx_pattern": "Dell.*", "detection": ["Registry", "WinGet"], "removable": true, "tier": "broad" },
        { "name": "Dell (AppX)", "appx_pattern": "DellInc.*", "detection": ["AppX"], "removable": true, "tier": "broad", "notes": "DellInc.DellDigitalDelivery / DellMobileConnect / DellSupportAssistforPCs" },
        { "name": "HP (winget)", "appx_pattern": "HP.*", "detection": ["Registry", "WinGet"], "removable": true, "tier": "broad" },
        { "name": "HP (AppX)", "appx_pattern": "AD2F1837.*", "detection": ["AppX"], "removable": true, "tier": "broad", "notes": "HP's AppX publisher prefix - covers myHP, HPSupportAssistant, HPJumpStarts, HPPrivacySettings, HPWelcome, etc." },
        { "name": "Lenovo (winget)", "appx_pattern": "Lenovo.*", "detection": ["Registry", "WinGet"], "removable": true, "tier": "broad" },
        { "name": "Lenovo Companion (AppX)", "appx_pattern": "E046963F.*", "detection": ["AppX"], "removable": true, "tier": "broad" },
        { "name": "Lenovo Vantage Service (AppX)", "appx_pattern": "LenovoCompanyLimited.*", "detection": ["AppX"], "removable": true, "tier": "broad" },
        { "name": "ASUS", "appx_pattern": "*ASUS*", "detection": ["AppX", "Registry", "WinGet"], "removable": true, "tier": "broad", "notes": "MyASUS, ArmouryCrate, GlideX, etc." },
        { "name": "Acer", "appx_pattern": "*Acer*", "detection": ["AppX", "Registry"], "removable": true, "tier": "broad" },
        { "name": "MSI Center", "appx_pattern": "*MSICenter*", "detection": ["AppX", "Registry"], "removable": true },
        { "name": "Razer", "appx_pattern": "*Razer*", "detection": ["AppX", "Registry"], "removable": true, "tier": "broad", "notes": "Matches Razer Synapse / Cortex, which is bundled bloat on a non-Razer machine but the actual peripheral-configuration app for Razer hardware owners" },
        { "name": "LG Monitor App", "appx_pattern": "*LGMonitor*", "detection": ["AppX"], "removable": true },
        { "name": "CyberLink (PowerDVD/PowerDirector)", "appx_pattern": "*CyberLink*", "detection": ["AppX", "Registry"], "removable": true, "tier": "broad", "notes": "PowerDirector is a legitimately-purchased video editor for some users, not just OEM-bundled PowerDVD trialware" },
        { "name": "Nero", "appx_pattern": "*Nero*", "detection": ["Registry"], "removable": true }
      ]

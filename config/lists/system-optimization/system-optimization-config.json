{
  "_comment": "v4.0 - OS-Specific system optimization configuration",
  "common": {
    "startupPrograms": {
      "safeToDisablePatterns": [
        "*Updater*",
        "*Update*Helper*",
        "*AutoUpdate*",
        "*UpdateChecker*",
        "*Adobe*Updater*",
        "*Google*Update*",
        "*Java*Update*"
      ],
      "neverDisable": [
        "*Security*",
        "*Antivirus*",
        "*Defender*",
        "*Firewall*",
        "*VPN*",
        "*Authentication*"
      ]
    },
    "services": {
      "safeToDisable": [
        "RetailDemo",
        "XblAuthManager",
        "XblGameSave",
        "XboxGipSvc",
        "XboxNetApiSvc"
      ],
      "_note": "DiagTrack and dmwappushservice moved to telemetry-list.json to avoid duplication"
    },
    "visualEffects": {
      "preset": "balanced",
      "disableAnimations": true,
      "disableShadows": true,
      "enableSmoothEdges": true,
      "enableShowWindowContents": true,
      "disableTransparency": true
    },
    "background": {
      "type": "Picture",
      "_comment": "Change from Windows Spotlight to Picture"
    },
    "powerPlan": {
      "defaultPlan": "High Performance"
    }
  },
  "windows10": {
    "services": {
      "safeToDisable": [],
      "_note": "WMPNetworkSvc moved to telemetry-list.json to avoid duplication"
    },
    "registryTweaks": {
      "_status": "not-implemented — no audit/apply path exists yet",
      "classicContextMenu": false,
      "showFileExtensions": true
    }
  },
  "windows11": {
    "services": {
      "safeToDisable": [
        "WidgetService",
        "DevHomeService"
      ],
      "_note": "ChatService removed — deprecated since Win11 23H2+"
    },
    "registryTweaks": {
      "_status": "not-implemented — no audit/apply path exists yet",
      "classicContextMenu": true,
      "showFileExtensions": true,
      "disableSnapLayouts": false,
      "centerTaskbar": false,
      "disableWidgets": true,
      "disableChat": true
    },
    "uiOptimizations": {
      "_status": "not-implemented — no audit/apply path exists yet",
      "useClassicTaskbar": false,
      "disableRecommendations": true,
      "minimizeSearchBox": true
    }
  }
}
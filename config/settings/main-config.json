{
  "execution": {
    "shutdown": {
      "countdownSeconds": 120,
      "cleanupOnTimeout": true,
      "rebootOnTimeout": true,
      "rebootOnlyWhenRequired": true
    }
  },
  "modules": {
    "skipSoftwareManagement": false,
    "skipSystemConfiguration": false,
    "skipDiskCleanup": false,
    "skipWindowsUpdates": false
  },
  "reporting": {
    "enableHtmlReport": true
  },
  "logging": {
    "_comment": "consoleLevel gates on-screen output; fileLevel gates maintenance.log. Levels: DEBUG < INFO/SUCCESS < WARN < ERROR < FATAL.",
    "consoleLevel": "INFO",
    "fileLevel": "DEBUG"
  }
}
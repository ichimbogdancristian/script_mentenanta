{
  "execution": {
    "shutdown": {
      "countdownSeconds": 120,
      "cleanupOnTimeout": true,
      "rebootOnTimeout": true,
      "rebootOnlyWhenRequired": true
    }
  },
  "modules": {
    "skipBloatwareRemoval": false,
    "skipEssentialApps": false,
    "skipWindowsUpdates": false,
    "skipTelemetryDisable": false,
    "skipSystemOptimization": false,
    "skipSecurityEnhancement": false,
    "skipAppUpgrade": false
  },
  "reporting": {
    "enableHtmlReport": true
  }
}